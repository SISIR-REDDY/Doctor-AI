rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Scanned bills / medical documents — owner-scoped (path segment is the uid).
    match /document_scans/{userId}/{file=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Patient photos and consultation audio. Authenticated access only.
    // (Path naming is not strictly uid-segmented, so we gate on auth.)
    match /patient_photos/{file=**} {
      allow read, write: if request.auth != null;
    }
    match /consultations/{file=**} {
      allow read, write: if request.auth != null;
    }
  }
}
