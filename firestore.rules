rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Shared API keys document — authenticated read only (no client writes).
    match /app_runtime/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Patient user root + all subcollections (profile, symptoms, meds, records, ai_chats, etc.)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
